# Use your preferred base image (e.g., node:20-alpine)
FROM node:20-alpine

WORKDIR /app

# Copy package files and install dependencies
# (Adjust these paths if your server and worker have separate package.json files)
COPY package*.json ./
RUN npm install

# Copy all the backend source code
COPY . .

# Ensure the start script is executable (just in case)
RUN chmod +x start.sh

# Expose your server port
EXPOSE 8080

# Run the combined startup script
CMD ["./start.sh"]