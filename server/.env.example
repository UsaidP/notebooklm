# ===================================
# SERVER ENVIRONMENT VARIABLES
# Copy this to server/.env.production
# ===================================

# ── Database (Railway PostgreSQL) ─────────────────────────────────────────────
# Get from Railway PostgreSQL service → Variables → DATABASE_URL
DATABASE_URL="postgresql://postgres:wFNZbmObatVYBwOslrHwGObMmXnLtwlp@postgres.railway.internal:5432/railway"

# ── Redis (Railway Redis/Valkey) ──────────────────────────────────────────────
# Get from Railway Redis service → Variables
REDISHOST="redis.railway.internal"
REDISPORT=6379
# If Redis requires password:
# REDIS_PASSWORD="your-password"

# ── Qdrant Vector Database ────────────────────────────────────────────────────
# Get from Railway Qdrant service → Variables
QDRANT_URL="http://your-qdrant-host.railway.internal:6333"
QDRANT_API_KEY=""  # Only if Qdrant requires authentication
QDRANT_COLLECTION="docs"
VECTOR_DIMENSION=1024

# ── Embedding Service ─────────────────────────────────────────────────────────
# Your custom embedding server URL (Modal, RunPod, or other)
EMBED_API_URL="https://your-embedding-server.com/v1/embeddings"
EMBED_MODEL="pplx-embed-v1"

# ── LLM Configuration (Groq) ──────────────────────────────────────────────────
# Get from https://console.groq.com/keys
GROQ_API_KEY="gsk_your_groq_api_key_here"
LLM_MODEL="llama-3.3-70b-versatile"

# ── Appwrite Storage ──────────────────────────────────────────────────────────
# Get from Appwrite Console → Project → Settings → API Keys
NEXT_PUBLIC_APPWRITE_ENDPOINT="https://cloud.appwrite.io/v1"
NEXT_PUBLIC_APPWRITE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_APPWRITE_BUCKET_ID="your-bucket-id"
NEXT_APP_WRITE_API_KEY="your-api-key"

# ── Client Configuration ──────────────────────────────────────────────────────
# Your Railway client URL (update after deployment)
CLIENT_URL="https://your-app.up.railway.app"

# ── Node Environment ──────────────────────────────────────────────────────────
NODE_ENV="production"

# ── Optional: Logging & Debug ─────────────────────────────────────────────────
# LOG_LEVEL="info"
# DEBUG="false"
