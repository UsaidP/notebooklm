QDRANT_API_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJhY2Nlc3MiOiJtIn0.4JJu0K2OzrmoaNG-d9MC3aFBAWI1QXPZ0222UwluicY"  # Only if Qdrant requires authentication
